JWT_SECRET=change-me
# DATABASE_URL is auto-detected: /data/ in Docker, ./data/ locally.
# Override only if you need a custom path, e.g.:
# DATABASE_URL=sqlite:////data/matrixpro.db
JWT_EXPIRY_HOURS=24
# MATRIXPRO_ENV=development
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# Logging (see ./start.sh --debug for file output)
# MATRIXPRO_LOG_LEVEL=INFO
# MATRIXPRO_LOG_FILE=0
# MATRIXPRO_LOG_DIR=./logs
# MATRIXPRO_LOG_RETENTION_DAYS=30
